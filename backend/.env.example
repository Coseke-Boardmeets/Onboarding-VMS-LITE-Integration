# ─────────────────────────────────────────────────────────
# Backend Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to Git — it is already in .gitignore.
# ─────────────────────────────────────────────────────────

# Port the Express server will listen on
PORT=4000

# PostgreSQL connection string
# Format: postgresql://<user>:<password>@<host>:<port>/<database>
# Example (local default): postgresql://postgres:postgres@localhost:5432/vms_lite
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/vms_lite"

# ── Prisma Postgres (alternative to standard PostgreSQL) ──
# If you are using Prisma's managed Postgres (via `prisma dev`),
# replace the DATABASE_URL above with the prisma+postgres:// URL
# printed by the CLI. Example:
# DATABASE_URL="prisma+postgres://localhost:51213/?api_key=..."
